{
  "name": "@alpacali/papyrus-cli",
  "version": "1.0.1",
  "description": "Papyrus CLI - Command line interface for Papyrus SRS learning system",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "papyrus": "dist/cli.js",
    "papyrus-cli": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "papyrus",
    "srs",
    "spaced-repetition",
    "flashcards",
    "learning",
    "cli",
    "study"
  ],
  "author": "Papyrus Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Papyrus/Papyrus-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Papyrus/Papyrus-cli/issues"
  },
  "homepage": "https://github.com/Papyrus/Papyrus-cli#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "inquirer": "^12.5.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.14.0",
    "typescript": "^5.8.3"
  }
}
