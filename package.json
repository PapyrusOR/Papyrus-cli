{
  "name": "@alpacali/papyrus-cli",
  "version": "1.0.3",
  "description": "Papyrus CLI - Command line interface for Papyrus SRS learning system",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "papyrus": "dist/cli.js",
    "papyrus-cli": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepublishOnly": "npm run quality && npm run build",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "papyrus",
    "srs",
    "spaced-repetition",
    "flashcards",
    "learning",
    "cli",
    "study"
  ],
  "author": "Papyrus Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Papyrus/Papyrus-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Papyrus/Papyrus-cli/issues"
  },
  "homepage": "https://github.com/Papyrus/Papyrus-cli#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "inquirer": "^12.5.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.24.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.1",
    "typescript": "^5.8.3"
  }
}
